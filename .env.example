# ============================================================
#  PLANTILLA DE VARIABLES DE ENTORNO — MI TIENDA
#  Copia este archivo como .env.local para desarrollo local
#  En producción estas variables se configuran como
#  GitHub Secrets y se inyectan automáticamente en Vercel
# ============================================================

# --- SUPABASE ---
# URL del proyecto Supabase (visible en Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clave pública anon (visible en Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Clave privada service_role — NUNCA exponerla en el cliente
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# --- SITIO ---
# URL pública de la tienda (ej: https://mi-tienda.vercel.app)
NEXT_PUBLIC_SITE_URL=https://tu-dominio.vercel.app

# --- BASE DE DATOS (Prisma) ---
# Cadena de conexión pooled (Transaction mode, puerto 6543)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Cadena de conexión directa (para migraciones, puerto 5432)
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
